{
  "name": "wayward2026",
  "version": "1.0.0",
  "description": "The Wayward | Portfolio of Jon Couch",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "storybook": "node node_modules/.bin/storybook dev -p 6006",
    "build-storybook": "node scripts/build-storybook.mjs",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@payloadcms/admin-bar": "3.84.1",
    "@payloadcms/db-sqlite": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-vercel-blob": "^3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@sparkjsdev/spark": "^0.1.10",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "isomorphic-dompurify": "^3.10.0",
    "leva": "^0.10.1",
    "lucide-react": "0.563.0",
    "motion": "^12.38.0",
    "next": "16.2.2",
    "next-sitemap": "^4.2.3",
    "payload": "3.84.1",
    "prism-react-renderer": "^2.3.1",
    "r3f-motion": "1.0.10",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-device-detect": "^2.2.3",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.1",
    "react-player": "^3.4.0",
    "react-scrollbars-custom": "^4.1.1",
    "sharp": "0.34.2",
    "storybook": "^10.3.4",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.58.2",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/manager-api": "^8.6.14",
    "@storybook/nextjs-vite": "^10.3.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/escape-html": "^1.0.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.4",
    "jsdom": "28.0.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.59.1",
    "postcss": "^8.4.38",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^6.2.0",
    "prettier": "^3.4.2",
    "storybook-addon-grid-overlay": "^1.0.1",
    "tailwindcss": "^3.4.17",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite": "^8.0.5",
    "vite-plugin-svgr": "^5.2.0",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "overrides": {
    "@joshwooding/vite-plugin-react-docgen-typescript": "0.7.0"
  }
}
